FROM python:3.11-slim
WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends build-essential git && rm -rf /var/lib/apt/lists/*
RUN git config --global --add safe.directory /app

COPY server/requirements.txt server/requirements-test.txt ./
RUN pip install --no-cache-dir -r requirements.txt -r requirements-test.txt \
    && pip install --no-cache-dir "diff-cover>=9.0"

COPY . .

WORKDIR /app/server
CMD ["bash", "-c", \
  "python -m pytest --cov=src --cov-report=xml:/app/coverage.xml \
  && python -m pytest tests/test_contract.py \
       --cov=src --cov-config=.coveragerc --cov-report=xml:/app/coverage.xml --cov-append \
       --override-ini='addopts=' -p no:xdist \
  && diff-cover /app/coverage.xml --compare-branch=origin/main --fail-under=95"]
