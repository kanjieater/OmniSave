# Copy to .env and fill in (never commit .env).
# No personal hostnames, domains, or host paths belong in the repo.

# Server (DNS / reverse proxy on your network)
# HOST = hostname only (no https://). PUBLIC_URL = full URL if you use TLS.
OMNISAVE_HOST=
OMNISAVE_PUBLIC_URL=

# Switch FTP for deploy.sh (deploy sysmodule only — not used by server)
OMNISAVE_SWITCHES=

# Repo and runtime install path
OMNISAVE_REPO=/path/to/OmniSave
OMNISAVE_ROOT=/mnt/srv/omnisave

# Docker
OMNISAVE_IMAGE=omnisave:latest
OMNISAVE_CONTAINER_NAME=omnisave
OMNISAVE_PORT_PUBLISH=8991
OMNISAVE_PORT_INTERNAL=8991
OMNISAVE_DOCKER_NETWORK=selfhost

# RomM integration (optional — leave blank to disable)
# ROMM_HOST=http://romm.lan:8080
# ROMM_API_KEY=
# ROMM_TITLE_MAP=/app/config/title_map.json
# ROMM_USER_MAP=/app/config/user_map.json

# Title name resolution for the dashboard (optional)
# Point to a local titledb JSON file mapping TitleID → name or {name: ...}
# Sources: tinfoil titledb, NsxLibraryManager, or switchbrew title lists
# OMNISAVE_TITLEDB=/app/config/titledb.json
