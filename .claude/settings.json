{
  "autoCompactEnabled": true,
  "model": "claude-sonnet-4-6",

  "permissions": {
    "allow": [
      "Bash(*docker run*)",
      "Bash(*docker exec*)",
      "Bash(*docker logs*)",
      "Bash(*sed*)",
      "Bash(*awk*)",
      "Bash(*grep*)",
      "Bash(*cat*)",
      "Bash(*tail*)",
      "Bash(*head*)",
      "Bash(*jq*)",
      "Bash(*curl*)",
      "Bash(*git*)",
      "Bash(*npm*)",
      "Bash(*npx*)",
      "Bash(*vite*)",
      "Bash(*python3*)",
      "Bash(*./scripts/server.sh*)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:npmjs.com)",
      "Bash(**docker run**)",
      "Bash(**docker logs**)",
      "Write(./context/frontend-v2-planning/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v rtk >/dev/null 2>&1; then rtk hook claude; else cat; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "path=$(jq -r '.tool_input.file_path'); if [ -f \"$path\" ] && [ $(wc -l < \"$path\") -gt 300 ]; then echo \"ERROR: $path exceeds 300 lines! Split this file immediately.\"; exit 1; fi; exit 0"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "timeout": 120,
            "statusMessage": "Fast tests (server Python)...",
            "command": "git -C /home/ke/code/OmniSaveServer status --porcelain -- server/ 2>/dev/null | grep -qE '\\.py$' && cd /home/ke/code/OmniSaveServer && docker compose run --rm test pytest --no-cov -x -q --override-ini='addopts=-n auto --dist loadscope --ignore=tests/test_contract.py' 2>&1 | tail -10 || true"
          }
        ]
      }
    ]
  }
}